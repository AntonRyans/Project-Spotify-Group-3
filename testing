def album_feature_summary(album_name, albums_df, features_df):
    """
    Returns a summary of audio feature scores for a given album.

    Parameters
    ----------
    album_name : str
        Name of the album to analyze
    albums_df : pandas.DataFrame
        Cleaned albums dataset
    features_df : pandas.DataFrame
        Cleaned features dataset

    Returns
    -------
    pandas.DataFrame
        Average feature values for the album
    """

    # Merge albums and features using track ID
    albums_features = albums_df.merge(
        features_df,
        left_on="track_id",
        right_on="id",
        how="inner"
    )

    # Select tracks from the requested album
    album_tracks = albums_features[
        albums_features["album_name"].str.lower() == album_name.lower()
    ]

    if album_tracks.empty:
        print(f"Album '{album_name}' not found.")
        return None

    # Feature columns to summarize
    feature_columns = [
        "danceability",
        "energy",
        "speechiness",
        "acousticness",
        "instrumentalness",
        "liveness",
        "valence",
        "tempo",
        "loudness"
    ]

    # Calculate mean feature values
    summary = album_tracks[feature_columns].mean()

    # Additional information
    num_tracks = len(album_tracks)
    album_popularity = album_tracks["album_popularity"].iloc[0]

    print("\nAlbum Feature Summary")
    print("----------------------")
    print("Album:", album_name)
    print("Number of tracks:", num_tracks)
    print("Album popularity:", album_popularity)
    print("\nAverage audio features:")
    print(summary)

    return summary