def clean_features(features_df):
    """
    Cleans the features dataset by:
    - removing missing IDs and missing numeric values
    - removing invalid/out-of-range values
    - removing duplicates
    """
    import pandas as pd

    initial_count = len(features_df)
    print("Initial number of tracks:", initial_count)

    # Remove rows with missing track ID
    features_df = features_df.dropna(subset=["id"])

    # Columns that must not be missing
    required_numeric = ["danceability", "energy", "speechiness", 
                        "acousticness", "instrumentalness", "liveness", 
                        "valence", "key", "mode", "loudness", "tempo", 
                        "duration_ms", "time_signature"]

    features_df = features_df.dropna(subset=required_numeric)

    # 1. Remove rows with numeric values out of expected range
    numeric_cols_0_1 = ["danceability", "energy", "speechiness", 
                        "acousticness", "instrumentalness", "liveness", "valence"]

    for col in numeric_cols_0_1:
        features_df = features_df[(features_df[col] >= 0) & (features_df[col] <= 1)]

    # 2. key must be integer 0-11
    features_df = features_df[features_df["key"].isin(range(0,12))]

    # 3. mode must be 0 or 1
    features_df = features_df[features_df["mode"].isin([0,1])]

    # 4. loudness <= 0
    features_df = features_df[features_df["loudness"] <= 0]

    # 5. tempo >= 0
    features_df = features_df[features_df["tempo"] >= 0]

    # 6. duration_ms > 0
    features_df = features_df[features_df["duration_ms"] > 0]

    # 7. time_signature valid
    features_df = features_df[features_df["time_signature"].isin([3,4,5])]

    # 8. Remove duplicates
    features_df = features_df.drop_duplicates()

    final_count = len(features_df)
    print("Number of tracks after cleaning:", final_count)
    print("Total rows removed:", initial_count - final_count)

    # Reset index
    features_df = features_df.reset_index(drop=True)

    return features_df

def clean_tracks(tracks_df):
    """
    Cleans the tracks dataset by:
    - removing missing IDs
    - ensuring track_popularity is 0-100
    - ensuring explicit is 0 or 1
    - removing duplicates
    """
    import pandas as pd

    initial_count = len(tracks_df)
    print("Initial number of tracks:", initial_count)

    # 1. Remove missing IDs
    tracks_df = tracks_df.dropna(subset=["id"])

    # 2. Ensure track_popularity is within 0-100
    tracks_df = tracks_df[(tracks_df["track_popularity"] >= 0) & 
                          (tracks_df["track_popularity"] <= 100)]

    # 3. Ensure explicit is 0 or 1
    tracks_df = tracks_df[tracks_df["explicit"].isin([0,1])]

    # 4. Remove duplicates
    tracks_df = tracks_df.drop_duplicates()

    final_count = len(tracks_df)
    print("Number of tracks after cleaning:", final_count)
    print("Total rows removed:", initial_count - final_count)

    # Reset index
    tracks_df = tracks_df.reset_index(drop=True)

    return tracks_df

