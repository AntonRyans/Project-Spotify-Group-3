def clean_albums(albums_df):
    """
    Cleans the albums dataset by:
    - removing missing IDs
    - removing invalid durations
    - checking popularity range
    - dropping empty columns
    - removing duplicates
    """

    initial_count = len(albums_df)
    print("Initial number of rows:", initial_count)

    # 1. Remove rows with missing critical IDs
    albums_df = albums_df.dropna(subset=["track_id", "album_id"])

    # 2. Remove invalid duration values
    albums_df = albums_df[albums_df["duration_ms"] > 0]
    albums_df = albums_df[albums_df["duration_sec"] > 0]

    # 3. Ensure album popularity is within valid range
    albums_df = albums_df[
        (albums_df["album_popularity"] >= 0) &
        (albums_df["album_popularity"] <= 100)
    ]

    # 4. Ensure total_tracks is positive
    albums_df = albums_df[albums_df["total_tracks"] > 0]

    # 5. Drop columns that are completely empty
    albums_df = albums_df.dropna(axis=1, how="all")

    # 6. Remove duplicate rows
    albums_df = albums_df.drop_duplicates()

    # Optional: remove duplicate tracks based on track_id
    albums_df = albums_df.drop_duplicates(subset=["track_id"])

    # Reset index
    albums_df = albums_df.reset_index(drop=True)

    final_count = len(albums_df)

    print("Number of rows after cleaning:", final_count)
    print("Total rows removed:", initial_count - final_count)

    return albums_df

def clean_artists(artists_df):
    """
    Cleans the artists dataset by:
    - removing missing IDs and names
    - ensuring popularity is within valid range
    - ensuring followers are non-negative
    - dropping empty genre columns
    - removing duplicates
    """

    initial_count = len(artists_df)
    print("Initial number of artists:", initial_count)

    # 1. Remove missing IDs or names
    artists_df = artists_df.dropna(subset=["id", "name"])

    # 2. Ensure artist popularity is within 0–100
    artists_df = artists_df[
        (artists_df["artist_popularity"] >= 0) &
        (artists_df["artist_popularity"] <= 100)
    ]

    # 3. Ensure followers are non-negative
    artists_df = artists_df[artists_df["followers"] >= 0]

    # 4. Drop columns that are completely empty
    artists_df = artists_df.dropna(axis=1, how="all")

    # 5. Remove duplicate rows
    artists_df = artists_df.drop_duplicates()

    # Optional: remove duplicate artists based on ID
    artists_df = artists_df.drop_duplicates(subset=["id"])

    # Reset index
    artists_df = artists_df.reset_index(drop=True)

    final_count = len(artists_df)

    print("Number of artists after cleaning:", final_count)
    print("Total rows removed:", initial_count - final_count)

    return artists_df

